# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aiops

# LLM provider: claude | openai
LLM_PROVIDER=claude

# API keys (set the one matching LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Training mode
# Set to false for production training with real data
# Demo mode:  ~90 seconds, good for presentations
# Full mode:  longer training, better for real network data
DEMO_MODE=true

# Demo-mode hyperparameters (override if needed)
DEMO_EPOCHS=8
DEMO_KPI_STREAM_SECONDS=600
DEMO_MAX_SAMPLES=200
DEMO_BATCH_SIZE=128
DEMO_LEARNING_RATE=0.01

# Full-mode hyperparameters (override if needed)
FULL_EPOCHS=100
FULL_KPI_STREAM_SECONDS=6000
FULL_MAX_SAMPLES=5000
FULL_BATCH_SIZE=32
FULL_LEARNING_RATE=0.001
